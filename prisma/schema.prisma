// Chore Safari - Prisma schema
// PostgreSQL backend. コイン残高・取引履歴・共有インベントリ・ガチャ履歴・どうぶつ図鑑を管理。
//
// 2026-05-17 大規模改修:
//   - Stage(ステージ) / Tool(道具) モデル新設
//   - Animal に habitat / stageId を追加
//   - ActiveTrap → Hunt にリネーム（罠/弓/槍を区別する huntType を追加）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CHILD
  PARENT

  @@map("user_role")
}

enum CoinTxKind {
  CHORE
  PENALTY
  BONUS
  GACHA
  ADJUSTMENT

  @@map("coin_tx_kind")
}

enum ItemType {
  FOOD       // エサ
  TRAP_PART  // 罠パーツ

  @@map("item_type")
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY

  @@map("rarity")
}

enum QuestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("quest_status")
}

// 狩りの種別。
//   TRAP  : 落とし穴・トラバサミなどのパッシブ罠（仕掛けて待つ）
//   BOW   : 複合弓などの飛び道具（ゲージ式タイミング）
//   SPEAR : アトラトル(投槍器)・槍などの投擲武器（ゲージ式タイミング）
enum HuntType {
  TRAP
  BOW
  SPEAR

  @@map("hunt_type")
}

// 道具種別。シードデータの type フィールドに対応。
enum ToolType {
  TRAP
  BOW
  SPEAR

  @@map("tool_type")
}

// 罠/狩りのライフサイクル。
//   PLACED   : 仕掛けたばかり/狙い始め。appears_at まで待機中。
//   APPEARED : appears_at を過ぎて動物が出現済み（タイミングゲーム可能）。
//   CAUGHT   : タイミングゲーム成功で捕獲済み。
//   ESCAPED  : 失敗で逃げられた。アイテムは戻ってこない。
enum HuntStatus {
  PLACED
  APPEARED
  CAUGHT
  ESCAPED

  @@map("hunt_status")
}

model User {
  id                String             @id @default(cuid())
  name              String
  // 年齢は保存せず、表示時にこの birth_date から動的に算出する
  birthDate         DateTime           @map("birth_date") @db.Date
  role              UserRole           @default(CHILD)
  coinBalance       Int                @default(0) @map("coin_balance")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  transactions       CoinTransaction[]
  gachaTransactions  GachaTransaction[]
  caughtAnimals      CaughtAnimal[]
  bonusNotifications SpecialBonusNotification[]
  questSubmissions   QuestSubmission[]
  hunts              Hunt[]
  // 専用クエストの対象となる場合
  targetedQuests     Quest[]
  // 専用ペナルティの対象となる場合
  targetedPenalties  Penalty[]

  @@map("users")
}

model CoinTransaction {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  kind      CoinTxKind
  reason    String?
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([userId])
  @@map("coin_transactions")
}

// 家族共有のインベントリ（倉庫）。アイテムごとに1行を持ち、quantity で個数を管理する。
model SharedInventoryItem {
  id        String   @id @default(cuid())
  itemId    String   @unique @map("item_id")
  itemName  String   @map("item_name")
  quantity  Int      @default(0)
  itemType  ItemType @map("item_type")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([itemType])
  @@map("shared_inventory")
}

// ガチャ履歴：誰がいつ何を引いたかを残す。
model GachaTransaction {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  costAmount Int      @map("cost_amount")
  itemId     String   @map("item_id")
  itemName   String   @map("item_name")
  itemType   ItemType @map("item_type")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("gacha_transactions")
}

// ─────────────────────────────────────────────────────────────
// 博物学ステージ（生息地カテゴリ）
//   name 例: "サバンナ" / "森林" / "氷河期" / "深海" / "恐竜時代"
//   unlockCondition は将来の段階開放用（NULL=最初から開放）。
// ─────────────────────────────────────────────────────────────
model Stage {
  id              String   @id @default(cuid())
  stageId         String   @unique @map("stage_id")     // "savanna" / "forest" / "ice_age" / "deep_sea" / "cretaceous"
  name            String                                  // 表示名
  emoji           String   @default("🌍")
  description     String   @default("")                  // ステージの解説
  // 解放条件（例: "図鑑を10種埋める" / null=最初から開放）
  unlockCondition String?  @map("unlock_condition")
  // 並び順（小さい数字ほど前に表示）
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  animals         Animal[]

  @@map("stages")
}

// ─────────────────────────────────────────────────────────────
// 道具マスタ：落とし穴・トラバサミ・アトラトル(投槍器)・複合弓 など。
//   type:        TRAP/BOW/SPEAR
//   successRateBonus: 命中率/捕獲率に加算される倍率(0.0〜1.0)
//   historicalContext: 「3万年前から使われたアトラトルは…」のような豆知識文。
// ─────────────────────────────────────────────────────────────
model Tool {
  id                String   @id @default(cuid())
  toolId            String   @unique @map("tool_id")        // "pitfall" / "leghold" / "atlatl" / "compound_bow"
  name              String                                    // 表示名
  emoji             String   @default("🛠️")
  description       String   @default("")                    // 道具の効果説明
  // 史実・歴史的背景。図鑑の道具タブで表示する。
  historicalContext String   @default("") @map("historical_context")
  type              ToolType
  // 0.00〜1.00。命中率に加算（0.20 なら +20%）。
  successRateBonus  Float    @default(0) @map("success_rate_bonus")
  // インベントリの itemId と紐付ける（消費アイテムとして登録されていれば連動）。
  // 罠は使い切り(消費)、弓・投槍器はストック扱い（消費 0）。
  inventoryItemId   String?  @map("inventory_item_id")
  consumable        Boolean  @default(true)
  // 並び順（小さい数字ほど前に表示）
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  hunts             Hunt[]

  @@index([type])
  @@map("tools")
}

// 図鑑マスタ：捕獲可能などうぶつの定義。
model Animal {
  id           String         @id @default(cuid())
  // ロジック上の識別子（'lion', 'rabbit', 'trex' など）。重複不可。
  animalId     String         @unique @map("animal_id")
  // ゲームプレイ中に表示する抽象名（例: ゾウ、カブトムシ）
  genericName  String         @default("") @map("generic_name")
  // 図鑑に載る詳細な種名（例: アフリカゾウ、ヘラクレスオオカブト）
  specificName String         @default("") @map("specific_name")
  // 後方互換：旧 name フィールド（新規はgenericeNameを使う）
  name         String
  rarity       Rarity
  // 約100文字の詳細解説文（図鑑で表示）
  description  String
  imageUrl     String?        @map("image_url")
  // 画像が無いときの表示用フォールバック絵文字。
  emoji        String         @default("🐾")
  // 絶滅種フラグ（true = 💀絶滅種バッジ表示）
  isExtinct    Boolean        @default(false) @map("is_extinct")
  // 生息地の自由記述（例: "アフリカのサバンナ" / "北極圏" / "中生代白亜紀"）
  habitat      String         @default("") @map("habitat")
  // どのステージに属するか（null=未分類/プレイ可能ながらステージ未割当）
  stageId      String?        @map("stage_id")
  stage        Stage?         @relation(fields: [stageId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  catches      CaughtAnimal[]
  hunts        Hunt[]

  @@index([rarity])
  @@index([genericName])
  @@index([stageId])
  @@map("animals")
}

// 捕獲履歴：かぞくでひとつの図鑑を共有する。
model CaughtAnimal {
  id             String   @id @default(cuid())
  animalId       String   @map("animal_id")
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  caughtByUserId String   @map("caught_by_user_id")
  caughtBy       User     @relation(fields: [caughtByUserId], references: [id], onDelete: Cascade)
  // どの罠とエサで捕まえたかの記録（後で組み合わせ確率を分析できるように残しておく）。
  trapItemId     String?  @map("trap_item_id")
  foodItemId     String?  @map("food_item_id")
  // どの道具（Tool）で捕まえたか。アクティブ狩りの記録用。
  toolId         String?  @map("tool_id")
  caughtAt       DateTime @default(now()) @map("caught_at")

  @@index([animalId])
  @@index([caughtByUserId])
  @@index([caughtAt])
  @@map("caught_animals")
}

// 特大達成ボーナス通知：親が送ったタイミングで未読(false)で作成され、
// 子供が /kids 画面で受け取って祝賀演出を出したら is_read=true に更新する。
model SpecialBonusNotification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  coinAmount Int      @map("coin_amount")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("special_bonus_notifications")
}

// クエストマスター：親があらかじめ定義する「やってほしいこと」。
model Quest {
  id          String            @id @default(cuid())
  title       String
  description String?
  rewardCoins Int               @map("reward_coins")
  emoji       String            @default("⭐")
  // 一覧から非表示にしたい時に使う（廃止クエスト）。
  isActive    Boolean           @default(true) @map("is_active")
  // クエストの属性。子供側の画面でセクション分けや色分けに使う。
  //   CHORE : おてつだい（掃除・配膳など）
  //   STUDY : おべんきょう（プリント・読書など）
  //   LIFE  : せいかつ（早起き・歯みがき・就寝など）
  // 値はアプリケーション側で検証する（DB 側は文字列のまま保持）。
  category    String            @default("CHORE")
  // 対象となる子供たち（空=全員用）
  targetUsers User[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  submissions QuestSubmission[]

  @@map("quests")
}

// クエスト申請：子供が「やったよ！」と申告すると PENDING で作られる。
// 親が承認すると APPROVED + コイン付与、差し戻すと REJECTED。
// 同じ (user, quest) でも複数回作れる（日課クエスト対応）。
model QuestSubmission {
  id          String      @id @default(cuid())
  questId     String      @map("quest_id")
  quest       Quest       @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      QuestStatus @default(PENDING)
  submittedAt DateTime    @default(now()) @map("submitted_at")
  reviewedAt  DateTime?   @map("reviewed_at")

  @@index([status])
  @@index([userId, status])
  @@index([questId])
  @@index([submittedAt])
  @@map("quest_submissions")
}

// 仕掛け中の罠 / 進行中の狩り（旧 ActiveTrap をリネーム）。
//   huntType=TRAP   : 罠スタイル（パッシブ）。setTrap で生成、appearsAt まで PLACED、過ぎたら APPEARED、
//                     タイミングゲームの結果で CAUGHT/ESCAPED。
//   huntType=BOW    : 複合弓（アクティブ狩り）。startHunt 直後にゲージ式タイミングで即決着。
//   huntType=SPEAR  : アトラトル/槍（アクティブ狩り）。BOW と同様にゲージ式タイミングで即決着。
//
// アクティブ狩りでは appearsAt は placedAt と同値（即時開始扱い）で保存。
// targetAnimalId は仕掛けた時に事前抽選した「もし成功したら捕まる」動物。
model Hunt {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  huntType        HuntType   @default(TRAP) @map("hunt_type")
  // どの道具で狩ったか（後方互換のため null 許容）。
  toolId          String?    @map("tool_id")
  tool            Tool?      @relation(fields: [toolId], references: [id], onDelete: SetNull)
  // 旧 ActiveTrap の trapItemId / baitItemId をそのまま維持（罠スタイル用）。
  trapItemId      String     @map("trap_item_id")
  baitItemId      String     @map("bait_item_id")
  status          HuntStatus @default(PLACED)
  placedAt        DateTime   @default(now()) @map("placed_at")
  appearsAt       DateTime   @map("appears_at")
  targetAnimalId  String     @map("target_animal_id")
  targetAnimal    Animal     @relation(fields: [targetAnimalId], references: [id], onDelete: Cascade)
  resolvedAt      DateTime?  @map("resolved_at")
  // 子供がフィールド上でタップした位置（% で 0〜100）
  posX            Float      @default(50) @map("pos_x")
  posY            Float      @default(50) @map("pos_y")

  @@index([userId, status])
  @@index([appearsAt])
  @@index([targetAnimalId])
  @@index([huntType])
  @@map("hunts")
}

// ペナルティマスタ：親が「やったらコイン没収」を事前定義しておく。
// targetUsers に含まれている子供だけが対象。空のときは全員用。
model Penalty {
  id          String   @id @default(cuid())
  title       String
  description String?
  // 没収するコイン枚数（正の整数）
  coinAmount  Int      @map("coin_amount")
  emoji       String   @default("🚨")
  isActive    Boolean  @default(true) @map("is_active")
  targetUsers User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("penalties")
}
