// Chore Safari - Prisma schema
// PostgreSQL backend. コイン残高・取引履歴・共有インベントリ・ガチャ履歴・どうぶつ図鑑を管理。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CHILD
  PARENT

  @@map("user_role")
}

enum CoinTxKind {
  CHORE
  PENALTY
  BONUS
  GACHA
  ADJUSTMENT

  @@map("coin_tx_kind")
}

enum ItemType {
  FOOD       // エサ
  TRAP_PART  // 罠パーツ

  @@map("item_type")
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY

  @@map("rarity")
}

enum QuestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("quest_status")
}

// サファリで仕掛けた罠のライフサイクル。
//   PLACED   : 仕掛けたばかり。appears_at まで待機中。
//   APPEARED : appears_at を過ぎて動物が出現済み（タイミングゲーム可能）。
//   CAUGHT   : タイミングゲーム成功で捕獲済み。
//   ESCAPED  : 失敗で逃げられた。アイテムは戻ってこない。
enum TrapStatus {
  PLACED
  APPEARED
  CAUGHT
  ESCAPED

  @@map("trap_status")
}

model User {
  id                String             @id @default(cuid())
  name              String
  // 年齢は保存せず、表示時にこの birth_date から動的に算出する
  birthDate         DateTime           @map("birth_date") @db.Date
  role              UserRole           @default(CHILD)
  coinBalance       Int                @default(0) @map("coin_balance")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  transactions       CoinTransaction[]
  gachaTransactions  GachaTransaction[]
  caughtAnimals      CaughtAnimal[]
  bonusNotifications SpecialBonusNotification[]
  questSubmissions   QuestSubmission[]
  activeTraps        ActiveTrap[]
  // 専用クエストの対象となる場合
  targetedQuests     Quest[]

  @@map("users")
}

model CoinTransaction {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  kind      CoinTxKind
  reason    String?
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([userId])
  @@map("coin_transactions")
}

// 家族共有のインベントリ（倉庫）。アイテムごとに1行を持ち、quantity で個数を管理する。
model SharedInventoryItem {
  id        String   @id @default(cuid())
  itemId    String   @unique @map("item_id")
  itemName  String   @map("item_name")
  quantity  Int      @default(0)
  itemType  ItemType @map("item_type")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([itemType])
  @@map("shared_inventory")
}

// ガチャ履歴：誰がいつ何を引いたかを残す。
model GachaTransaction {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  costAmount Int      @map("cost_amount")
  itemId     String   @map("item_id")
  itemName   String   @map("item_name")
  itemType   ItemType @map("item_type")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("gacha_transactions")
}

// 図鑑マスタ：捕獲可能などうぶつの定義。
model Animal {
  id          String         @id @default(cuid())
  // ロジック上の識別子（'lion', 'rabbit', 'trex' など）。重複不可。
  animalId    String         @unique @map("animal_id")
  name        String
  rarity      Rarity
  description String
  imageUrl    String?        @map("image_url")
  // 画像が無いときの表示用フォールバック絵文字。
  emoji       String         @default("🐾")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  catches     CaughtAnimal[]
  activeTraps ActiveTrap[]

  @@index([rarity])
  @@map("animals")
}

// 捕獲履歴：かぞくでひとつの図鑑を共有する。
model CaughtAnimal {
  id             String   @id @default(cuid())
  animalId       String   @map("animal_id")
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  caughtByUserId String   @map("caught_by_user_id")
  caughtBy       User     @relation(fields: [caughtByUserId], references: [id], onDelete: Cascade)
  // どの罠とエサで捕まえたかの記録（後で組み合わせ確率を分析できるように残しておく）。
  trapItemId     String?  @map("trap_item_id")
  foodItemId     String?  @map("food_item_id")
  caughtAt       DateTime @default(now()) @map("caught_at")

  @@index([animalId])
  @@index([caughtByUserId])
  @@index([caughtAt])
  @@map("caught_animals")
}

// 特大達成ボーナス通知：親が送ったタイミングで未読(false)で作成され、
// 子供が /kids 画面で受け取って祝賀演出を出したら is_read=true に更新する。
model SpecialBonusNotification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  coinAmount Int      @map("coin_amount")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("special_bonus_notifications")
}

// クエストマスター：親があらかじめ定義する「やってほしいこと」。
model Quest {
  id          String            @id @default(cuid())
  title       String
  description String?
  rewardCoins Int               @map("reward_coins")
  emoji       String            @default("⭐")
  // 一覧から非表示にしたい時に使う（廃止クエスト）。
  isActive    Boolean           @default(true) @map("is_active")
  // 対象となる子供たち（空=全員用）
  targetUsers User[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  submissions QuestSubmission[]

  @@map("quests")
}

// クエスト申請：子供が「やったよ！」と申告すると PENDING で作られる。
// 親が承認すると APPROVED + コイン付与、差し戻すと REJECTED。
// 同じ (user, quest) でも複数回作れる（日課クエスト対応）。
model QuestSubmission {
  id          String      @id @default(cuid())
  questId     String      @map("quest_id")
  quest       Quest       @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      QuestStatus @default(PENDING)
  submittedAt DateTime    @default(now()) @map("submitted_at")
  reviewedAt  DateTime?   @map("reviewed_at")

  @@index([status])
  @@index([userId, status])
  @@index([questId])
  @@index([submittedAt])
  @@map("quest_submissions")
}

// 仕掛け中の罠。setTrap で生成、appears_at までは PLACED、過ぎたら APPEARED、
// タイミングゲームの結果で CAUGHT / ESCAPED に決まる。
// target_animal_id は仕掛けた時に事前抽選した「もし成功したら捕まる」動物。
model ActiveTrap {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trapItemId      String     @map("trap_item_id")
  baitItemId      String     @map("bait_item_id")
  status          TrapStatus @default(PLACED)
  placedAt        DateTime   @default(now()) @map("placed_at")
  appearsAt       DateTime   @map("appears_at")
  targetAnimalId  String     @map("target_animal_id")
  targetAnimal    Animal     @relation(fields: [targetAnimalId], references: [id], onDelete: Cascade)
  resolvedAt      DateTime?  @map("resolved_at")

  @@index([userId, status])
  @@index([appearsAt])
  @@index([targetAnimalId])
  @@map("active_traps")
}
